{
 "cells": [
  {
   "cell_type": "markdown",
   "id": "step1_ml_intro",
   "metadata": {},
   "source": [
    "# Step 5: Data Preprocessing, Anomaly Cleansing, and One-Hot Encoding\n",
    "\n",
    "### 1 - DATASET INGESTION & OUTLIER ANOMALY RECONCILIATION\n",
    "* **Our Solution:** Load checkpoint, impute 1 adult for ghost bookings, hard-cap ADR outliers at $500, and group rare countries."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "step1_ml_code",
   "metadata": {},
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "df = pd.read_csv('bookings_with_holiday_features.csv')\n",
    "ghost_mask = (df['adults'] + df['children'] + df['babies']) == 0\n",
    "df.loc[ghost_mask, 'adults'] = 1\n",
    "df = df[df['adr'] >= 0].copy()\n",
    "df.loc[df['adr'] > 500.0, 'adr'] = 500.0\n",
    "country_counts = df['country'].value_counts(dropna=False)\n",
    "rare_countries = country_counts[country_counts < 10].index\n",
    "df['country'] = df['country'].replace(rare_countries, 'Other')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step2_ml_preprocessing_overview",
   "metadata": {},
   "source": [
    "### 2 - EXPLICIT NULL ALLOCATION & ONE-HOT ENCODING"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "step2_ml_preprocessing_code",
   "metadata": {},
   "source": [
    "y = df['is_canceled'].copy()\n",
    "features_to_drop = ['is_canceled', 'booking_date', 'arrival_date', 'departure_date']\n",
    "X_raw = df.drop(columns=features_to_drop)\n",
    "X_raw['country'] = X_raw['country'].fillna('Unknown')\n",
    "X_raw['agent'] = X_raw['agent'].fillna(-1).astype('int64')\n",
    "categorical_columns = ['hotel', 'deposit_type', 'market_segment', 'meal', 'customer_type', 'distribution_channel', 'reserved_room_type', 'country']\n",
    "X = pd.get_dummies(X_raw, columns=categorical_columns, drop_first=True)\n",
    "bool_columns = X.select_dtypes(include=['bool']).columns\n",
    "X[bool_columns] = X[bool_columns].astype(int)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step3_split_overview",
   "metadata": {},
   "source": [
    "### 3 - CHRONOLOGICAL TEMPORAL SPLITTING"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "step3_split_code",
   "metadata": {},
   "source": [
    "arrival_dates_series = pd.to_datetime(df['arrival_date'])\n",
    "cutoff_boundary = arrival_dates_series.min() + pd.DateOffset(months=18)\n",
    "train_mask = arrival_dates_series < cutoff_boundary\n",
    "test_mask = arrival_dates_series >= cutoff_boundary\n",
    "X_train, X_test = X[train_mask].copy(), X[test_mask].copy()\n",
    "y_train, y_test = y[train_mask].copy(), y[test_mask].copy()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "model_comparison_intro",
   "metadata": {},
   "source": [
    "### 4 - ALGORITHM BENCHMARKING (Champion vs. Challenger)\n",
    "Results show HistGradientBoosting (ROC-AUC 0.9032) outperforms Random Forest (0.8818)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "model_comparison_code",
   "metadata": {},
   "source": [
    "from sklearn.ensemble import HistGradientBoostingClassifier, RandomForestClassifier\n",
    "from sklearn.metrics import roc_auc_score, log_loss\n",
    "import time\n",
    "models = {\n",
    "    \"Random Forest (Baseline)\": RandomForestClassifier(n_estimators=100, max_depth=12, random_state=42, n_jobs=-1),\n",
    "    \"HistGradientBoosting (Advanced)\": HistGradientBoostingClassifier(max_iter=150, max_depth=6, learning_rate=0.08, random_state=42)\n",
    "}\n",
    "for name, model in models.items():\n",
    "    model.fit(X_train, y_train)\n",
    "    probs = model.predict_proba(X_test)[:, 1]\n",
    "    print(f\"{name}: ROC-AUC={roc_auc_score(y_test, probs):.4f}, Log-Loss={log_loss(y_test, probs):.4f}\")\n",
    "xgb_model = models[\"HistGradientBoosting (Advanced)\"]"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "leakage_analysis_and_remediation",
   "metadata": {},
   "source": [
    "### 5 - FEATURE IMPORTANCE & DATA LEAKAGE REMEDIATION\n",
    "After discovering leakage in `segment_cancels_on_booking_date` and `segment_bookings_made_on_booking_date`, these were removed to ensure operational validity."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "leakage_remediation_code",
   "metadata": {},
   "source": [
    "leakage_cols = ['segment_cancels_on_booking_date', 'segment_bookings_made_on_booking_date']\n",
    "X_clean = X.drop(columns=[col for col in leakage_cols if col in X.columns])\n",
    "X_train_clean, X_test_clean = X_clean[train_mask], X_clean[test_mask]\n",
    "xgb_model.fit(X_train_clean, y_train)\n",
    "print(\"Model re-calibrated successfully without leakage variables.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "final_pipeline_generator",
   "metadata": {},
   "source": [
    "### 6 - OPERATIONAL PORTFOLIO ETL PIPELINE (TIME MACHINE)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "step5_pipeline_generator_code",
   "metadata": {},
   "source": [
    "booking_dates, arrival_dates = pd.to_datetime(df['booking_date']), pd.to_datetime(df['arrival_date'])\n",
    "simulation_days = pd.date_range(start='2015-10-01', end='2017-08-15', freq='D')\n",
    "bi_export_list = []\n",
    "for current_date in simulation_days:\n",
    "    mask = (booking_dates <= current_date) & (arrival_dates > current_date) & (arrival_dates <= current_date + pd.Timedelta(days=30))\n",
    "    sim_idx = df[mask].index\n",
    "    if len(sim_idx) == 0: continue\n",
    "    probs = xgb_model.predict_proba(X_clean.loc[sim_idx])[:, 1]\n",
    "    df_slice = df.loc[sim_idx].copy()\n",
    "    df_slice['raw_prob'], df_slice['standing_date'] = probs, current_date\n",
    "    df_slice['exposure_score'] = df_slice['raw_prob'].clip(0, 1)\n",
    "    bi_export_list.append(df_slice[['standing_date', 'arrival_date', 'is_canceled', 'raw_prob', 'exposure_score', 'hotel', 'market_segment']])\n",
    "final_bi_dataset = pd.concat(bi_export_list, ignore_index=True)\n",
    "final_bi_dataset.to_csv('bi_dashboard_pipeline_output.csv', index=False)\n",
    "print(f\"Exported {final_bi_dataset.shape[0]:,} records.\")"
   ]
  }
 ],
